  <style>
    :root {
      --bg:      #030804;
      --surface: #060d07;
      --text:    #d4ead6;
      --muted:   #4a6b4d;
      --accent:  #00ff41;
      --accent2: #39e84a;
      --accent3: #ff3860;
      --dim:     rgba(0,255,65,0.06);
      --border:  rgba(0,255,65,0.14);
      --border2: rgba(0,255,65,0.06);
      --glow:    0 0 24px rgba(0,255,65,0.2);
      --BIG:     'Bebas Neue', sans-serif;
      --MONO:    'Share Tech Mono', monospace;
      --SERIF:   'Cormorant Garamond', serif;
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{background:var(--bg);color:var(--text);font-family:var(--MONO);font-size:13px;line-height:1.7;overflow-x:hidden;cursor:none}
    a{color:inherit;text-decoration:none}
    ::-webkit-scrollbar{width:3px}
    ::-webkit-scrollbar-track{background:var(--bg)}
    ::-webkit-scrollbar-thumb{background:var(--accent);border-radius:2px}

    body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");opacity:.03;pointer-events:none;z-index:9999}
    body::after{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,rgba(0,0,0,.025) 0px,rgba(0,0,0,.025) 1px,transparent 1px,transparent 4px);pointer-events:none;z-index:9998}

    #cur-dot{position:fixed;width:7px;height:7px;background:var(--accent);border-radius:50%;pointer-events:none;z-index:10001;transform:translate(-50%,-50%);box-shadow:0 0 10px var(--accent),0 0 28px rgba(0,255,65,.3)}
    #cur-ring{position:fixed;width:34px;height:34px;border:1px solid rgba(0,255,65,.45);border-radius:0;pointer-events:none;z-index:10000;transform:translate(-50%,-50%) rotate(45deg);transition:width .3s,height .3s,border-color .3s}
    #cur-ring::before,#cur-ring::after{content:'';position:absolute;background:var(--accent)}
    #cur-ring::before{top:-2px;left:-2px;width:4px;height:4px}
    #cur-ring::after{bottom:-2px;right:-2px;width:4px;height:4px}
    body.hov #cur-dot{background:var(--accent2);box-shadow:0 0 14px var(--accent2)}
    body.hov #cur-ring{width:52px;height:52px;border-color:var(--accent2)}

    #progress{position:fixed;top:0;left:0;height:2px;background:var(--accent);width:0%;z-index:9997;box-shadow:var(--glow);transition:width .08s linear}

    @keyframes blink{0%,100%{opacity:1}50%{opacity:0}}
    .blink{animation:blink 1s step-end infinite}
    @keyframes fu{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:none}}

    /* NAV */
    nav{position:fixed;top:0;left:0;right:0;display:flex;justify-content:space-between;align-items:center;padding:1.5rem 3rem;background:rgba(3,8,4,.88);backdrop-filter:blur(14px);border-bottom:1px solid var(--border2);z-index:900}
    .nav-logo{font-family:var(--BIG);font-size:1.7rem;letter-spacing:.06em;color:var(--accent)}
    .nav-back{display:flex;align-items:center;gap:.6rem;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);transition:color .25s;cursor:none}
    .nav-back:hover{color:var(--accent)}
    .nav-back::before{content:'←';color:var(--accent)}
    .nav-links{display:flex;gap:2.5rem;list-style:none}
    .nav-links a{font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);transition:color .25s}
    .nav-links a:hover{color:var(--accent)}

    /* HERO BANNER */
    #proj-hero{
      min-height:65vh;
      display:flex;flex-direction:column;justify-content:flex-end;
      padding:0 3rem 4rem;
      position:relative;overflow:hidden;
    }
    .ph-grid{position:absolute;inset:0;background-image:linear-gradient(var(--border2) 1px,transparent 1px),linear-gradient(90deg,var(--border2) 1px,transparent 1px);background-size:55px 55px}
    .ph-orb{position:absolute;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(0,255,65,.055) 0%,transparent 65%);top:50%;right:-80px;transform:translateY(-50%);pointer-events:none}
    .ph-num{position:absolute;right:3rem;bottom:4rem;font-family:var(--BIG);font-size:clamp(10rem,20vw,18rem);color:rgba(0,255,65,.04);line-height:1;pointer-events:none;user-select:none}

    .proj-eyebrow{font-size:10px;letter-spacing:.3em;text-transform:uppercase;color:var(--accent2);margin-bottom:1.2rem;position:relative;z-index:1;opacity:0;animation:fu .7s .2s ease forwards}
    .proj-title-big{font-family:var(--BIG);font-size:clamp(3.5rem,9vw,8rem);line-height:.88;letter-spacing:.02em;position:relative;z-index:1;opacity:0;animation:fu .7s .4s ease forwards}
    .proj-title-big .gr{color:var(--accent)}
    .proj-meta-row{display:flex;gap:2rem;flex-wrap:wrap;margin-top:1.5rem;position:relative;z-index:1;opacity:0;animation:fu .7s .6s ease forwards}
    .proj-badge{font-size:9px;letter-spacing:.15em;text-transform:uppercase;padding:.3rem .8rem;border:1px solid rgba(0,255,65,.2);color:var(--accent)}
    .proj-badge.y{border-color:rgba(255,204,0,.25);color:#ffcc00}
    .proj-badge.r{border-color:rgba(255,56,96,.2);color:var(--accent3)}
    .proj-stat-row{display:flex;gap:3rem;margin-top:2rem;position:relative;z-index:1;opacity:0;animation:fu .7s .8s ease forwards}
    .ps{font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)}
    .ps span{display:block;font-family:var(--BIG);font-size:1.6rem;color:var(--accent);letter-spacing:.04em;line-height:1}

    /* CONTENT */
    .proj-body{max-width:900px;margin:0 auto;padding:6rem 3rem}

    /* TOC */
    .toc{border:1px solid var(--border2);background:var(--surface);padding:1.8rem 2rem;margin-bottom:4rem}
    .toc-title{font-family:var(--BIG);font-size:1.2rem;letter-spacing:.06em;color:var(--accent);margin-bottom:1rem}
    .toc-list{list-style:none;display:flex;flex-direction:column;gap:.4rem}
    .toc-list a{font-size:12px;letter-spacing:.08em;color:var(--muted);display:flex;align-items:center;gap:.6rem;transition:color .2s;cursor:none}
    .toc-list a:hover{color:var(--accent)}
    .toc-list a::before{content:counter(toc-counter,decimal-leading-zero);counter-increment:toc-counter;font-size:10px;color:var(--accent);opacity:.6}
    .toc-list{counter-reset:toc-counter}

    /* Sections */
    .ws{margin-bottom:4rem}
    .ws-label{font-size:10px;letter-spacing:.28em;text-transform:uppercase;color:var(--accent);display:flex;align-items:center;gap:.8rem;margin-bottom:1rem}
    .ws-label::before{content:'';width:20px;height:1px;background:var(--accent)}
    .ws-heading{font-family:var(--BIG);font-size:clamp(1.8rem,4vw,3rem);letter-spacing:.04em;line-height:.95;margin-bottom:1.5rem}
    .ws p{font-size:13px;color:var(--muted);line-height:2;margin-bottom:1.2rem}
    .ws p strong{color:var(--text);font-weight:400}
    .ws p .hi{color:var(--accent)}

    /* Objectives list */
    .obj-list{list-style:none;display:flex;flex-direction:column;gap:.6rem;margin-bottom:1.5rem}
    .obj-list li{font-size:13px;color:var(--muted);padding-left:1.4rem;position:relative;line-height:1.8}
    .obj-list li::before{content:'>';position:absolute;left:0;color:var(--accent)}
    .obj-list strong{color:var(--text);font-weight:400}

    /* Code/terminal block */
    .terminal{background:#020503;border:1px solid var(--border);margin:1.5rem 0;overflow:hidden}
    .term-header{display:flex;justify-content:space-between;align-items:center;padding:.6rem 1rem;border-bottom:1px solid var(--border2);background:var(--surface)}
    .term-dots{display:flex;gap:.4rem}
    .term-dots span{width:8px;height:8px;border-radius:50%}
    .term-dots span:nth-child(1){background:var(--accent3)}
    .term-dots span:nth-child(2){background:#ffcc00}
    .term-dots span:nth-child(3){background:var(--accent2)}
    .term-label{font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:var(--muted)}
    .term-body{padding:1.2rem 1.4rem;font-size:12px;line-height:1.9;overflow-x:auto}
    .term-body .prompt{color:var(--accent2)}
    .term-body .cmd{color:var(--text)}
    .term-body .comment{color:var(--muted)}
    .term-body .output{color:rgba(212,234,214,.5)}
    .term-body .hi{color:var(--accent)}

    /* Info callout */
    .callout{border-left:3px solid var(--accent);background:var(--dim);padding:1.2rem 1.5rem;margin:1.5rem 0}
    .callout-label{font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);margin-bottom:.5rem}
    .callout p{font-size:12px;color:var(--muted);line-height:1.9;margin:0}
    .callout p strong{color:var(--text);font-weight:400}
    .callout.warn{border-color:var(--accent3);background:rgba(255,56,96,.04)}
    .callout.warn .callout-label{color:var(--accent3)}

    /* Screenshot placeholder */
    .screenshot{width:100%;border:1px solid var(--border2);background:var(--surface);aspect-ratio:16/7;display:flex;align-items:center;justify-content:center;margin:1.5rem 0;position:relative;overflow:hidden;transition:border-color .3s}
    .screenshot:hover{border-color:var(--border)}
    .screenshot::before{content:'';position:absolute;inset:0;background:repeating-linear-gradient(45deg,transparent,transparent 30px,rgba(0,255,65,.015) 30px,rgba(0,255,65,.015) 31px)}
    .screenshot-label{font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);text-align:center}
    .screenshot-label span{display:block;font-family:var(--BIG);font-size:1.5rem;color:rgba(0,255,65,.2);margin-bottom:.4rem}

    /* Findings table */
    .findings-table{width:100%;border-collapse:collapse;margin:1.5rem 0;font-size:12px}
    .findings-table th{font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);padding:.6rem .8rem;border-bottom:1px solid var(--border);text-align:left}
    .findings-table td{padding:.7rem .8rem;border-bottom:1px solid var(--border2);color:var(--muted);vertical-align:top;line-height:1.7}
    .findings-table tr:hover td{color:var(--text);background:var(--dim)}
    .sev{font-size:9px;letter-spacing:.1em;text-transform:uppercase;padding:.2rem .5rem;border:1px solid}
    .sev.high{color:var(--accent3);border-color:rgba(255,56,96,.3)}
    .sev.med{color:#ffcc00;border-color:rgba(255,204,0,.3)}
    .sev.low{color:var(--accent2);border-color:rgba(57,232,74,.3)}
    .sev.info{color:var(--muted);border-color:rgba(74,107,77,.3)}

    /* Key takeaways */
    .takeaways{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin:1.5rem 0}
    .ta{border:1px solid var(--border2);background:var(--surface);padding:1.2rem;transition:border-color .3s,box-shadow .3s}
    .ta:hover{border-color:var(--border);box-shadow:var(--glow)}
    .ta-num{font-family:var(--BIG);font-size:2rem;color:rgba(0,255,65,.15);line-height:1;margin-bottom:.4rem}
    .ta-text{font-size:12px;color:var(--muted);line-height:1.8}
    .ta-text strong{color:var(--text);font-weight:400}

    /* Nav between projects */
    .proj-nav{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-top:5rem;padding-top:3rem;border-top:1px solid var(--border2)}
    .pnav{border:1px solid var(--border2);padding:1.2rem 1.5rem;transition:border-color .3s,box-shadow .3s;cursor:none}
    .pnav:hover{border-color:var(--border);box-shadow:var(--glow)}
    .pnav.next{text-align:right}
    .pnav-dir{font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:.4rem}
    .pnav-title{font-family:var(--BIG);font-size:1.2rem;letter-spacing:.04em;color:var(--text)}
    .pnav-arrow{color:var(--accent);font-size:1rem}

    /* REVEAL */
    .rv{opacity:0;transform:translateY(36px);transition:opacity .7s ease,transform .7s ease}
    .rv.on{opacity:1;transform:none}
    .d1{transition-delay:.1s}.d2{transition-delay:.2s}.d3{transition-delay:.3s}

    footer{padding:1.8rem 3rem;border-top:1px solid var(--border2);display:flex;justify-content:space-between;align-items:center}
    .ft-l{font-size:11px;letter-spacing:.08em;color:var(--muted)}
    .ft-l span{color:var(--accent)}
    .ft-r{font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted)}

    @media(max-width:768px){
      nav{padding:1.2rem 1.5rem}
      .nav-links{display:none}
      #proj-hero{padding:0 1.5rem 3rem;min-height:50vh}
      .proj-body{padding:4rem 1.5rem}
      .takeaways{grid-template-columns:1fr}
      .proj-nav{grid-template-columns:1fr}
      .proj-stat-row{gap:1.5rem}
      footer{flex-direction:column;gap:.8rem;text-align:center}
    }
  </style>
</head>
